# Postgres connection settings for apps/store's persistence adapter.
#
# Copy this file to a local, untracked `.env` (or export the variables
# directly) before running store integration tests or the store outside
# Docker Compose. Never commit real credentials — these are local
# development placeholders only. Docker Compose (compose.yaml,
# compose.debug.yaml) already sets these for the containerized `spoolstore`
# service; this template is for host-side test runs against the compose
# `postgres` service published on localhost:5433.

STORE_DB_HOST=localhost
STORE_DB_PORT=5433
STORE_DB_USER=spool
STORE_DB_PASSWORD=spool_dev
STORE_DB_NAME=spool

# Base directory for LocalFileBlobStore (Meridian IDEA-85). Optional for host-side test runs —
# defaults to a directory under the OS temp dir when unset. Docker Compose sets this explicitly
# to a path backed by the spoolstore-artifact-data named volume.
# ARTIFACT_BLOB_STORE_PATH=/tmp/spool-artifacts
